# ── База данных ───────────────────────────────────────────────
# Локально (PostgreSQL на машине):
DATABASE_URL=postgresql://postgres:postgres123@localhost:5433/odir_db
# На проде — строка подключения Supabase (Session Pooler, порт 5432):
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ── Авторизация ───────────────────────────────────────────────
SECRET_KEY=change_this_to_a_long_random_string

# ── Фронтенд (CORS) ───────────────────────────────────────────
# Адрес фронтенда на Vercel (несколько — через запятую):
# FRONTEND_URL=https://your-app.vercel.app

# ── Хранилище файлов (опционально) ────────────────────────────
# Если заданы — снимки и Grad-CAM грузятся в Supabase Storage.
# Если пусто — файлы пишутся на локальный диск.
# SUPABASE_URL=https://<ref>.supabase.co
# SUPABASE_SERVICE_KEY=<service_role_key>
# SUPABASE_BUCKET=scans
